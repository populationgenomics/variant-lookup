# Copy to .env and fill in. .env must not be committed.
# See ARCHITECTURE.md § "Configuration" for the full reference.

# --- Storage ---
DATA_DIR=/absolute/path/to/reference/data
# Absolute paths to TLS materials for nginx. The files are mounted individually
# at the names nginx expects (cert.pem / key.pem inside the container), so your
# host filenames can be anything. nginx runs its master as root inside the
# container, so root-only host perms on the key are fine — no copy needed.
SSL_CERT_FILE=/absolute/path/to/server-cert-plus-intermediates.pem
SSL_KEY_FILE=/absolute/path/to/server.key
API_KEYS_HOST_FILE=/absolute/path/to/api-keys.yaml

# --- Network ---
NGINX_PORT=9443

# --- Upstreams ---
NCBI_EUTILS_EMAIL=you@example.org
# Optional — raises NCBI rate limit from 3 to 10 req/sec.
NCBI_EUTILS_API_KEY=

# --- Pinned echtvar release for the gateway image build ---
ECHTVAR_VERSION=v0.2.4

# --- Pinned mutalyzer-api package version (used by docker/mutalyzer-api build) ---
MUTALYZER_API_VERSION=0.3.2

# --- Pinned amazon/aws-cli image (used by setup.sh refresh-echtvar) ---
AWS_CLI_VERSION=2.34.30

# --- mutalyzer-api gunicorn worker count (sibling container) ---
# Each worker maintains its own in-process reference-sequence LRU on top of
# the shared file cache. Memory scales linearly: ~100 MB per chromosomal
# reference per worker once warmed. 4 is a reasonable starting point.
MUTALYZER_API_WORKERS=4

# --- Version metadata stamped into /v1/variants responses ---
# variantvalidator + mutalyzer versions are auto-detected at runtime from
# VV's /hello banner and mutalyzer-api's /api/version endpoint respectively.
SERVICE_VERSION=0.1.0+dev
GNOMAD_VERSION=4.1
