# Copy to .env and fill in. .env must not be committed.
# See ARCHITECTURE.md § "Configuration" for the full reference.

# --- Storage ---
DATA_DIR=/absolute/path/to/reference/data
SSL_CERT_PATH=/absolute/path/to/cert/dir
API_KEYS_HOST_FILE=/absolute/path/to/api-keys.yaml

# --- Network ---
NGINX_PORT=9443

# --- Upstreams ---
NCBI_EUTILS_EMAIL=you@example.org
# Optional — raises NCBI rate limit from 3 to 10 req/sec.
NCBI_EUTILS_API_KEY=

# --- Pinned echtvar release for the gateway image build ---
ECHTVAR_VERSION=v0.2.4

# --- Version metadata stamped into /v1/variants responses ---
SERVICE_VERSION=0.1.0+dev
GNOMAD_VERSION=4.1
VARIANTVALIDATOR_VERSION=3.0.x+dev
MUTALYZER_VERSION=unknown
